{
  "name": "idle-bank-empire",
  "version": "1.0.135",
  "description": "Idle Bank Empire - Clicker & Simulation Game",
  "main": "app.js",
  "scripts": {
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "bundle": "node tools/bundle.js",
    "css": "node tools/build-css.js",
    "verify": "node tools/verify-integrity.js",
    "build": "npm run verify && npm run bundle && npm run css && node tools/build.js",
    "cap-build": "npm run build && node build.js",
    "cap-sync": "npm run cap-build && npx cap sync",
    "verify-android-sync": "node tools/verify-android-sync.js",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "sass": "^1.101.0",
    "sharp": "^0.35.2",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "idle",
    "tycoon",
    "game"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor-firebase/crashlytics": "^8.3.0",
    "@capacitor/android": "^8.4.1",
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/splash-screen": "^8.0.1"
  }
}
